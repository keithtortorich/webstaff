# WebStaffr Environment — copy to .env and fill in values

# OpenAI
OPENAI_API_KEY=sk-...

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# SendGrid
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=hello@webstaffr.com
SENDGRID_FROM_NAME=WebStaffr

# Database (SQLite for dev, Postgres for production)
DATABASE_URL=sqlite:///./webstaffr.db
# DATABASE_URL=postgresql://user:password@host:5432/webstaffr

# App
APP_SECRET_KEY=change-me-in-production
BASE_URL=http://localhost:8000
ENVIRONMENT=development

# FSM Integrations — Phase 1: Zapier bridges (no FSM credentials needed)
ZAPIER_SERVICETITAN_WEBHOOK_URL=
ZAPIER_JOBBER_WEBHOOK_URL=
ZAPIER_HCP_WEBHOOK_URL=

# ServiceTitan — Phase 2: native API (leave blank until Phase 2)
# ST_CLIENT_ID=
# ST_CLIENT_SECRET=
# ST_TENANT_ID=
# ST_API_BASE=https://api.servicetitan.io
